# ── Dispatch — environment ──────────────────────────────────────────────
# Copy to .env and fill in. The pipeline runs end-to-end with ZERO keys
# (heuristic classify + keyword precedent recall) so you can build offline first.

# Slack app credentials (T-02) — Sandbox app → OAuth & Permissions / Basic Information
SLACK_BOT_TOKEN=xoxb-...            # Bot token
SLACK_APP_TOKEN=xapp-...            # App-level token (connections:write) for Socket Mode
SLACK_SIGNING_SECRET=...            # Basic Information → Signing Secret

# Optional: user token with search:read.public for RTS without an action_token (T-07)
SLACK_USER_TOKEN=xoxp-...

# The channel Dispatch watches (T-03). Leave blank to listen on all channels it's in.
DISPATCH_CHANNEL_ID=C0XXXXXXX

# Classification LLM (T-11) — swap for Slack AI if exposed in your sandbox.
# If unset, classify() uses a zero-dependency heuristic so the pipeline still runs.
LLM_API_KEY=
LLM_URL=https://api.anthropic.com/v1/messages
LLM_MODEL=claude-haiku-4-5

# Embeddings provider for the RTS fallback (T-09). If unset, rts.ts degrades to
# keyword recall over the seeded corpus — the GATE is never blocked on this.
EMBED_API_KEY=
EMBED_URL=https://api.openai.com/v1/embeddings
EMBED_MODEL=text-embedding-3-small

# Demo safety (T-19) — true = deterministic precedent for a clean one-take recording.
USE_FAKES=false
