{
  "display_information": {
    "name": "Dispatch",
    "description": "Mutual-aid coordination agent — intake, classify, match, recall.",
    "background_color": "#1f6feb"
  },
  "features": {
    "bot_user": {
      "display_name": "dispatch",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Find the right volunteer for any community need."
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "chat:write",
        "im:history",
        "search:read.public"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_started",
        "assistant_thread_context_changed",
        "message.channels",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
